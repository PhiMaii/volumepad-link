{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Runtime": {
    "PipeName": "VolumePadLink.Agent.v2",
    "UseSimulatorDevice": true,
    "UseSimulatedAudioFallback": true,
    "DataDirectory": "",
    "SimulatorPortName": "SIMULATED",
    "DefaultAutoConnectPort": "SIMULATED",
    "DeviceRequestTimeoutMs": 1500,
    "AutoReconnectDelayMs": 1200
  },
  "Queues": {
    "EventCapacity": 512,
    "DeviceHighCapacity": 128,
    "DeviceMediumCapacity": 128,
    "DeviceLowCapacity": 64,
    "RingControlCapacity": 128,
    "RingAnimationCapacity": 96,
    "RingMeterCapacity": 1
  }
}
